# ── Aplicação ──────────────────────────────────────────────────────────────
# URL base da API backend (sem barra no final)
API_BASE_URL=http://localhost:8080

# Porta exposta pelo container no host (apenas para docker-compose local)
PORT=80

# ── AWS / ECS Fargate ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Nome do repositório no ECR (ex: hack-vp-site)
ECR_REPOSITORY=hack-vp-site

# Nome do cluster ECS
ECS_CLUSTER=hack-vp-cluster

# Nome do serviço ECS
ECS_SERVICE=hack-vp-service

# Nome (ou ARN) da task definition ECS
ECS_TASK_DEFINITION=hack-vp-task

# Nome do container dentro da task definition
CONTAINER_NAME=hack-vp-site
